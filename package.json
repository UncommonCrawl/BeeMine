{
  "name": "beemine",
  "version": "1.0.0",
  "private": true,
  "description": "Static web app powered by Vite.",
  "scripts": {
    "dev": "vite --host localhost --port 5173",
    "start": "npm run dev",
    "generate:daily-schedule": "node scripts/generate-daily-schedule.mjs",
    "count:entry-lengths": "node scripts/count-entry-lengths.js",
    "build": "vite build",
    "preview": "vite preview --host localhost --port 4173",
    "test": "vitest run"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
